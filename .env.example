# vellum configuration — copy to .env and adjust.

# HTTP listen port
PORT=8080

# Host port published by docker compose (container always listens on 8080)
VELLUM_PORT=8080

# Root directory of the markdown vault.
# Local run: ./vault — in Docker the volume is mounted at /vault.
VELLUM_VAULT_PATH=./vault

# Create inbox/projects/archive when the vault is empty (default true)
VELLUM_INIT_STRUCTURE=true

# Names of the conventional directories
VELLUM_INBOX_DIR=inbox
VELLUM_PROJECTS_DIR=projects
VELLUM_ARCHIVE_DIR=archive
