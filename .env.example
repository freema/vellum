# vellum configuration — copy to .env and adjust.

# HTTP listen port
PORT=8080

# Host port published by docker compose (container always listens on 8080)
VELLUM_PORT=8080

# Root directory of the markdown vault.
# Local run: ./vault — in Docker the volume is mounted at /vault.
VELLUM_VAULT_PATH=./vault

# Create inbox/projects/archive when the vault is empty (default true)
VELLUM_INIT_STRUCTURE=true

# Names of the conventional directories
VELLUM_INBOX_DIR=inbox
VELLUM_PROJECTS_DIR=projects
VELLUM_ARCHIVE_DIR=archive

# AI curator tools (suggest_*/find_* — context only, never calls an LLM)
VELLUM_CURATOR=off

# Browser origins allowed to call /mcp (comma-separated).
# Non-browser clients (Claude Code CLI) are not affected.
VELLUM_ALLOWED_ORIGINS=https://claude.ai,https://claude.com

# --- OAuth (one client secret is the access key) ---

# Enable auth. Without it /mcp is open — fine locally, never in public.
AUTH_ENABLED=true

# Client credentials. Generate the secret: openssl rand -hex 32
VELLUM_CLIENT_ID=vellum
VELLUM_CLIENT_SECRET=

# Public HTTPS URL when behind a reverse proxy (Caddy/Traefik).
# WITHOUT THIS the OAuth metadata advertises localhost and clients fail.
VELLUM_ISSUER_URL=

# Set behind a reverse proxy so rate limiting sees real client IPs.
TRUST_PROXY=1

# Origins receiving CORS headers (default: VELLUM_ALLOWED_ORIGINS)
CORS_ORIGINS=https://claude.ai,https://claude.com

# Optional exact redirect URI allowlist (empty = allow any).
# Claude callback: https://claude.ai/api/mcp/auth_callback
VELLUM_REDIRECT_URIS=

# --- SMTP task digest (optional, off by default) ---

# Email a periodic digest of open tasks. Needs SMTP_HOST/FROM/TO to activate.
VELLUM_NOTIFY=off
# Cadence as a Go duration (e.g. 24h, 12h). Default 24h.
VELLUM_NOTIFY_INTERVAL=24h
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# --- Sentry error reporting (optional, off unless a DSN is set) ---

# vellum is open source — set YOUR OWN Sentry DSN here (never commit a real one).
# Example shape: https://<key>@<org>.ingest.<region>.sentry.io/<project>
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
